{
  "$schema": "http://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "virtualNetworkName": {
      "type": "string",
      "defaultValue": "cisco-virtualnet",
      "metadata": {
        "description": "Nome da Virtual Network que será criada"
      }
    },
    "virtualNetworkCidr": {
      "type": "string",
      "defaultValue": "10.0.0.0/16",
      "metadata": {
        "description": "CIDR da Virtual Network"
      }
    },
    "mgmtSubnet": { "type": "string", "defaultValue": "cisco-mgmt-subnet" },
    "insideSubnet": { "type": "string", "defaultValue": "cisco-inside-subnet" },
    "outsideSubnet": { "type": "string", "defaultValue": "cisco-outside-subnet" },
    "cclSubnet": { "type": "string", "defaultValue": "ccl" },
    "functionAppSubnet": { "type": "string", "defaultValue": "function-app-subnet" },

    "mgmtSubnetCIDR": { "type": "string", "defaultValue": "10.0.1.0/24" },
    "insideSubnetCIDR": { "type": "string", "defaultValue": "10.0.3.0/24" },
    "outsideSubnetCIDR": { "type": "string", "defaultValue": "10.0.4.0/24" },
    "cclSubnetCIDR": { "type": "string", "defaultValue": "10.0.5.0/24" },
    "functionAppSubnetCIDR": { "type": "string", "defaultValue": "10.0.6.0/24" }
  },
  "variables": {
    "networkApiVersion": "2023-09-01"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "[variables('networkApiVersion')]",
      "name": "[parameters('virtualNetworkName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('virtualNetworkCidr')]"
          ]
        },
        "subnets": [
          {
            "name": "[parameters('mgmtSubnet')]",
            "properties": {
              "addressPrefix": "[parameters('mgmtSubnetCIDR')]"
            }
          },
          {
            "name": "[parameters('insideSubnet')]",
            "properties": {
              "addressPrefix": "[parameters('insideSubnetCIDR')]"
            }
          },
          {
            "name": "[parameters('outsideSubnet')]",
            "properties": {
              "addressPrefix": "[parameters('outsideSubnetCIDR')]"
            }
          },
          {
            "name": "[parameters('cclSubnet')]",
            "properties": {
              "addressPrefix": "[parameters('cclSubnetCIDR')]"
            }
          },
          {
            "name": "[parameters('functionAppSubnet')]",
            "properties": {
              "addressPrefix": "[parameters('functionAppSubnetCIDR')]"
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "virtualNetworkId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]"
    },
    "mgmtSubnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('mgmtSubnet'))]"
    }
  }
}
